# ─────────────────────────────────────────────────────────────
# Memento — environment template
#
# Copy this file to `.env` (or let ./install.sh do it for you)
# and fill in the values you care about.
#
# Required secrets — if omitted, the installer generates random
# values on first run. Never commit these to a public repo.
# ─────────────────────────────────────────────────────────────

# Signs JWTs. Must be >= 32 chars, high entropy.
MEMENTO_SECRET_KEY=

# Token used by collectors to register themselves.
MEMENTO_COLLECTOR_TOKEN=

# Postgres superuser password (keep in sync with MEMENTO_DATABASE_URL).
POSTGRES_PASSWORD=

# MinIO / S3 credentials.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ─────────────────────────────────────────────────────────────
# Optional — AI backends for daily summaries & graph extraction
# ─────────────────────────────────────────────────────────────

# Anthropic Claude (for `/api/daily/*/generate-summary`). Leave blank to disable.
ANTHROPIC_API_KEY=

# Alternate OpenAI-compatible endpoint (Aliyun / Kimi / etc.)
# Leave blank to disable the alt backend.
MEMENTO_AI_API_KEY=
MEMENTO_AI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
MEMENTO_AI_MODEL=kimi-k2.5

# ─────────────────────────────────────────────────────────────
# Optional — embedding server (semantic search + MCP memory recall)
# ─────────────────────────────────────────────────────────────
#
# BGE-M3 runs on the HOST (not in Docker — needs GPU passthrough).
# The api container talks to it via this URL. Default works for both:
#   - Docker Desktop (Mac / Windows): host.docker.internal auto-resolves
#   - Linux: docker-compose.yml adds an extra_hosts entry that maps
#     host.docker.internal to the host gateway (Docker 20.10+)
#
# Override only if you run the embedding server somewhere else (a
# different machine on the LAN, a separate process, etc.):
#   MEMENTO_EMBEDDING_SERVER_URL=http://192.168.1.x:8002
MEMENTO_EMBEDDING_SERVER_URL=http://host.docker.internal:8002

# ─────────────────────────────────────────────────────────────
# Optional — PyPI mirror for Docker build (slow / blocked networks)
# ─────────────────────────────────────────────────────────────
#
# Default empty = use pypi.org directly. If `docker compose build` times
# out reading files.pythonhosted.org, set a faster mirror here. The api +
# celery-worker + celery-beat services all honor this build arg.
#
# Mainland China options:
#   PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
#   PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
#   PIP_INDEX_URL=https://pypi.mirrors.ustc.edu.cn/simple/
# PIP_INDEX_URL=
