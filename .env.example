# ─────────────────────────────────────────────────────────────
# Memento — environment template
#
# Copy this file to `.env` (or let ./install.sh do it for you)
# and fill in the values you care about.
#
# Required secrets — if omitted, the installer generates random
# values on first run. Never commit these to a public repo.
# ─────────────────────────────────────────────────────────────

# Signs JWTs. Must be >= 32 chars, high entropy.
MEMENTO_SECRET_KEY=

# Token used by collectors to register themselves.
MEMENTO_COLLECTOR_TOKEN=

# Postgres superuser password (keep in sync with MEMENTO_DATABASE_URL).
POSTGRES_PASSWORD=

# MinIO / S3 credentials.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ─────────────────────────────────────────────────────────────
# Optional — AI backends for daily summaries & graph extraction
# ─────────────────────────────────────────────────────────────

# Anthropic Claude (for `/api/daily/*/generate-summary`). Leave blank to disable.
ANTHROPIC_API_KEY=

# Alternate OpenAI-compatible endpoint (Aliyun / Kimi / etc.)
# Leave blank to disable the alt backend.
MEMENTO_AI_API_KEY=
MEMENTO_AI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
MEMENTO_AI_MODEL=kimi-k2.5
