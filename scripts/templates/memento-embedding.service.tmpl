[Unit]
Description=Memento BGE-M3 Embedding Server
After=network.target

[Service]
Type=simple
WorkingDirectory={repo}/server
ExecStart={python} -m server.services.embedding_server --port 8002
Restart=on-failure
RestartSec=10
Environment=PYTORCH_ENABLE_MPS_FALLBACK=1
Environment=PATH={path}
Environment=MEMENTO_EMBEDDING_MODEL_NAME={model}
StandardOutput=append:{logdir}/embedding_stdout.log
StandardError=append:{logdir}/embedding_stderr.log

[Install]
WantedBy=default.target
