{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Memento desktop — permission set for window + sidecar + dialog + shell open.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "core:app:default",
    "core:path:default",

    "log:default",
    "autostart:default",
    "single-instance:default",
    "dialog:default",

    "shell:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "memento-collector-sidecar", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        { "name": "memento-collector-sidecar", "sidecar": true }
      ]
    }
  ]
}
